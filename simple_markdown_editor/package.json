{
  "name": "simple-markdown-editor",
  "version": "0.4.5",
  "description": "A stupid simple markdown editor",
  "main": "src/main/main.js",
  "author": {
    "name": "mipyip",
    "url": "https://mipyip.com"
  },
  "homepage": "https://github.com/avanrossum/simple-markdown-editor",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && electron . --dev",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && electron-builder --config electron-builder.config.js",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "diff": "^7.0.0",
    "dompurify": "^3.3.1",
    "electron-updater": "^6.3.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.7.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/language-data": "^6.5.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.0",
    "@lezer/highlight": "^1.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "codemirror": "^6.0.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
